# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Public Variables - IPFS Gateways
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
NEXT_PUBLIC_CF_IPFS_GATEWAY=https://ipfs.cinachain.com
NEXT_PUBLIC_CF_CDN_GATEWAY=https://cdn.cinachain.com
NEXT_PUBLIC_CF_META_GATEWAY=https://meta.cinachain.com

# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Public Variables - Ethereum Gateways
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
NEXT_PUBLIC_CF_RPC_ENDPOINT=https://rpc.cinachain.com
NEXT_PUBLIC_MAINNET_RPC=https://mainnet-rpc.cinachain.com
NEXT_PUBLIC_BASE_RPC=https://base-rpc.cinachain.com

# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Public Variables - App Configuration
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
NEXT_PUBLIC_CINA_NFT_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WC_PROJECT_ID=your-walletconnect-project-id
NEXT_PUBLIC_SITE_URL=https://nft.cinachain.com
NEXT_PUBLIC_USE_PUBLIC_PROVIDER=true
NEXT_PUBLIC_PROD_NETWORKS_DEV=false

# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Private Variables
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Generate one here: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=

# Cloudflare RPC Service Tokens
CF_RPC_SERVICE_AUTH_TOKEN=
CF_BASE_RPC_SERVICE_AUTH_TOKEN=

# Admin addresses (comma-separated)
APP_ADMINS="0x9D81DeFB5Bed0D14db479f8E736ACa79A72E8eED"
NEXT_PUBLIC_APP_ADMINS="0x9D81DeFB5Bed0D14db479f8E736ACa79A72E8eED"
