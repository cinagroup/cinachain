# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Public Variables
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Cloudflare IPFS Gateway
NEXT_PUBLIC_CF_IPFS_GATEWAY=https://ipfs.cinachain.com

# Cloudflare RPC Gateway
NEXT_PUBLIC_CF_RPC_ENDPOINT=https://rpc.cinachain.com/v1

# NFT Contract Address (update after deployment)
NEXT_PUBLIC_CINA_NFT_CONTRACT=0x0000000000000000000000000000000000000000

# WalletConnect Project ID (Reown)
NEXT_PUBLIC_WC_PROJECT_ID=c8867b3035029c2152dd54b3c9d0ae80

# Website URL
NEXT_PUBLIC_SITE_URL=https://nft.cinachain.com

# Public Provider (for testing)
NEXT_PUBLIC_USE_PUBLIC_PROVIDER=true

# Enables the use of production networks in the development environment
NEXT_PUBLIC_PROD_NETWORKS_DEV=false

# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Private Variables
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Generate one here: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=

# Cloudflare RPC Service Token
CF_RPC_SERVICE_AUTH_TOKEN=

# Admin addresses (comma-separated)
# Example: "0x123,0x456"
APP_ADMINS=""

# Public admin addresses for frontend (comma-separated)
NEXT_PUBLIC_APP_ADMINS=""
